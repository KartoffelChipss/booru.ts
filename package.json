{
    "name": "booru.ts",
    "version": "1.0.1",
    "description": "A TypeScript library for interacting with the Booru APIs.",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "test": "tsc && jest",
        "test:unit": "tsc && jest tests/unit",
        "test:integration": "tsc && jest tests/integration",
        "prepublishOnly": "tsc",
        "format": "prettier --write 'src/**/*.{ts,tsx}'",
        "testapp": "tsc && cd testapp && tsc && node ./dist/index.js",
        "docs": "typedoc --options typedoc.json",
        "opendocs": "pnpm run docs && open ./docs/index.html"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/KartoffelChipss/booru.ts.git"
    },
    "bugs": {
        "url": "https://github.com/KartoffelChipss/booru.ts/issues"
    },
    "author": {
        "name": "Jan Straßburger",
        "email": "contact@strassburger.org",
        "url": "https://strassburger.org/"
    },
    "keywords": [
        "booru",
        "booru-api",
        "rule34",
        "r34",
        "danbooru",
        "gelbooru",
        "safebooru"
    ],
    "license": "MIT",
    "readme": "README.md",
    "devDependencies": {
        "@types/bun": "latest",
        "@types/jest": "^29.5.12",
        "@types/node": "^22.7.4",
        "jest": "^29.7.0",
        "prettier": "^3.5.3",
        "ts-jest": "^29.1.5",
        "typedoc": "^0.27.9",
        "typedoc-github-theme": "^0.2.1"
    },
    "peerDependencies": {
        "typescript": "^5.6.2"
    },
    "dependencies": {
        "node-cache": "^5.1.2"
    }
}
